{
  "global": {
    "basePath": "Funkin"
  },
  "gameplay": {
    "strumline": {
      "assetPath": "notes/noteStrumline",
      "scale": 0.7,
      "alpha": 1.0,
      "offsets": {
        "static": [0, 0],
        "press": [30, 30],
        "confirm": [0, 0]
      },
      "animations": {
        "left": {
          "static": "staticLeft",
          "press": "pressLeft",
          "confirm": "confirmLeft"
        },
        "down": {
          "static": "staticDown",
          "press": "pressDown",
          "confirm": "confirmDown"
        },
        "up": {
          "static": "staticUp",
          "press": "pressUp",
          "confirm": "confirmUp"
        },
        "right": {
          "static": "staticRight",
          "press": "pressRight",
          "confirm": "confirmRight"
        }
      }
    },
    "notes": {
      "assetPath": "notes/notes",
      "scale": 0.7,
      "alpha": 1.0,
      "Offset": [0, 0],
      "animations": {
        "left": "noteLeft",
        "down": "noteDown",
        "up": "noteUp",
        "right": "noteRight"
      }
    },
    "sustains": {
      "assetPath": "notes/NOTE_hold_assets",
      "scale": 0.6,
      "alpha": 1.0,
      "Offset": [-4, 0],
      "OffsetHit": [0, 0],
      "animations": {
        "left": {
          "body": "purple hold piece",
          "end": "purple hold end"
        },
        "down": {
          "body": "blue hold piece",
          "end": "blue hold end"
        },
        "up": {
          "body": "green hold piece",
          "end": "green hold end"
        },
        "right": {
          "body": "red hold piece",
          "end": "red hold end"
        }
      }
    },
    "noteSplashes": {
      "assetPath": "notes/noteSplashes",
      "scale": 0.9,
      "alpha": 1,
      "Offset": [0, -10],
      "animations": {
        "left": ["note impact 1 purple", "note impact 2 purple"],
        "down": ["note impact 1 blue", "note impact 2 blue"],
        "up": ["note impact 1 green", "note impact 2 green"],
        "right": ["note impact 1 red", "note impact 2 red"]
      }
    },
    "holdCovers": {
      "scale": 1,
      "alpha": 1.0,
      "Offset": [-10, 45],
      "directions": {
        "left": {
          "assetPath": "notes/holdCovers/holdCoverPurple",
          "animations": {
            "start": "holdCoverStartPurple",
            "hold": "holdCoverPurple",
            "end": "holdCoverEndPurple"
          }
        },
        "down": {
          "assetPath": "notes/holdCovers/holdCoverBlue",
          "animations": {
            "start": "holdCoverStartBlue",
            "hold": "holdCoverBlue",
            "end": "holdCoverEndBlue"
          }
        },
        "up": {
          "assetPath": "notes/holdCovers/holdCoverGreen",
          "animations": {
            "start": "holdCoverStartGreen",
            "hold": "holdCoverGreen",
            "end": "holdCoverEndGreen"
          }
        },
        "right": {
          "assetPath": "notes/holdCovers/holdCoverRed",
          "animations": {
            "start": "holdCoverStartRed",
            "hold": "holdCoverRed",
            "end": "holdCoverEndRed"
          }
        }
      }
    }
  },
